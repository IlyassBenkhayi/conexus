# ── Server Configuration ─────────────────────────────────────────────────────
PORT=3001

# ── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production. A dev-only fallback is used if not set.
JWT_SECRET=

# ── Server URL (for file upload URLs) ────────────────────────────────────────
# Used to construct absolute URLs for uploaded files.
# In production, set this to your public server URL (e.g. https://api.conexus.app)
SERVER_URL=http://localhost:3001

# ── Twitch API (optional) ────────────────────────────────────────────────────
# Used for Twitch stream/VOD search. Register a Twitch application at
# https://dev.twitch.tv/console/apps to get a Client-ID.
# TWITCH_CLIENT_ID=
